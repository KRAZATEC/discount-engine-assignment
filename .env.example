# Copy this file to .env.local and fill in your own Groq API key.
# Get a free key at https://console.groq.com/keys
#
# .env.local is already git-ignored — never commit real keys.

VITE_GROQ_API_KEY=your-groq-api-key-here

# Optional — defaults to llama-3.3-70b-versatile if not set.
# Any current Groq chat model works, e.g. llama-3.1-8b-instant for faster/cheaper parsing.
VITE_GROQ_MODEL=llama-3.3-70b-versatile
